{
  "name": "ctf-buster",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "remoteUser": "ctf",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "serayuzgur.crates",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "rust-analyzer.cargo.buildScripts.enable": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.check.extraArgs": ["--", "-W", "clippy::all"],
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tools/tests/"],
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer",
          "editor.tabSize": 2
        },
        "files.watcherExclude": {
          "**/target/**": true
        }
      }
    }
  },
  "features": {},
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "postCreateCommand": "cargo build --release 2>&1 | tail -1",
  "forwardPorts": [],
  "mounts": [
    "source=ctf-buster-cargo-cache,target=/home/ctf/.cargo/registry,type=volume",
    "source=ctf-buster-target-cache,target=/workspace/target,type=volume",
    "source=ctf-buster-claude-config,target=/home/ctf/.claude,type=volume"
  ]
}
